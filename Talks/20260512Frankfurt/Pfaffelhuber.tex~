\begin{frame}
  \frametitle{Das Mischungs.Modell} 
  \begin{itemize}
  \item $x_{ijm}$: Anzahl des Allels $j$ in Individuum $i$ bei Marker $m$
  \item $p_{kjm}$: Häufigkeit von Allel $j$ an Marker $m$ in Population $k$,
  \item $q_{ik}$: Anteil der Ancestry von Individuum $i$ in Population $k$. 
  \item Parameter: Maximierung von
  \begin{align*}
    \ell(q, p|x)  & = C_x + \frac 1{2MN} \sum_{i=1}^N \sum_{m=1}^M  \sum_{j=1}^{J_m} x_{ijm} \log(q_{i \cdot} p_{\cdot j m}^\top).
  \end{align*}
  \item Wie gut sind Schätzer für $p, q$?
  \item Idee: Auf der rechten Seite stehen $q$ und $p$ nicht getrennt, sondern nur deren Produkt. \\
  Da $qp = qS^{-1} Sp$, sind $q$ und $p$ nicht eindeutig. Welche Rolle spielt das für Schätzer von $p$ und $q$?
\end{itemize}

\end{frame}



